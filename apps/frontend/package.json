{
  "name": "instech-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "api:generate": "rm -rf src/api/generated && orval --config orval.config.ts",
    "build": "vite build",
    "dev": "vite dev --port 8800",
    "generate-routes": "tsr generate",
    "intent:install": "npx @tanstack/intent@latest install",
    "intent:list": "npx @tanstack/intent@latest list",
    "lint": "yarn lint:eslint && yarn lint:biome",
    "lint:biome": "biome check .",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix && biome check --write .",
    "lint:staged": "lint-staged",
    "preview": "vite preview",
    "tanstack:create": "tanstack create",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "5.2.8",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/query-core": "5.101.0",
    "@tanstack/react-devtools": "0.10.7",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/router-core": "1.171.13",
    "@tanstack/router-plugin": "1.168.18",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.21.0",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/cli": "0.69.4",
    "@tanstack/devtools-vite": "0.8.0",
    "@tanstack/intent": "0.3.2",
    "@tanstack/router-cli": "1.167.17",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.62.0",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.5.0",
    "eslint-plugin-perfectionist": "5.9.1",
    "eslint-plugin-sort-destructure-keys": "3.0.0",
    "globals": "17.7.0",
    "jsdom": "28.1.0",
    "lint-staged": "17.0.8",
    "orval": "8.18.0",
    "shadcn": "4.11.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "biome check --write"
    ],
    "*.{json,jsonc}": [
      "biome check --write"
    ]
  },
  "packageManager": "yarn@4.17.0"
}